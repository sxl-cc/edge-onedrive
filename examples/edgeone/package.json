{
  "name": "edgeone",
  "version": "1.0.0",
  "private": "true",
  "type": "module",
  "scripts": {
    "build": "pnpm -w build:api && pnpm -w build:ui && tsdown",
    "dev": "cd dist && edgeone pages dev",
    "deploy-edge": "pnpm build && cd dist && edgeone pages deploy"
  },
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "api": "workspace:*"
  },
  "devDependencies": {
    "tsdown": "0.22.0"
  }
}
